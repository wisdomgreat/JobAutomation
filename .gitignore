# --- Sovereign Agent: Privacy Shield .gitignore ---

# Environment & Private Keys
.env
.env.local
.env.production
*.pem
*.key

# Python / Environment
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
venv/
.venv/
node_modules/
.python-version
.pytest_cache/

# User Data & Private Assets (Mission Critical Privacy)
# ALL files in data/ are excluded except for .example files or the folder itself
data/*
!data/.gitkeep
!data/*.example
!data/README.md

# Build & Release Artifacts
dist/
build/
*.spec
*.exe
*.bin
SovereignAgent
venv_build/

# IDE / Project Config
.vscode/
.idea/
*.swp
*.swo
*.code-workspace

# Runtime Debris & Logs
logs/
debug/
tmp/
output/
scratch/
test_output/
.agent/
.gemini/
.braid/

# OS-specific
.DS_Store
Thumbs.db

# UI Guide & Temporary Assets
image/GUIDE_AI/
image/temp/
