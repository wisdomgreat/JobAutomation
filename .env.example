# ══════════════════════════════════════════════════════════════
# SOVEREIGN AGENT - CONFIGURATION TEMPLATE
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your details.

# ── AI Intelligence Hub ──────────────────────────────────────
# Options: openai, gemini, anthropic, groq, openrouter, ollama
LLM_PROVIDER=openrouter

# OpenRouter (Recommended for Free Models like Gemini 2.0 Flash)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# OpenAI (Alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (Local - Privacy Focused)
# Requires Ollama running locally: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Job Hunter Identification ───────────────────────────────
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_secure_password

INDEED_EMAIL=
INDEED_PASSWORD=

# ── Mission Parameters ──────────────────────────────────────
TARGET_ROLES="Cloud Architect, DevOps Engineer, Support Specialist"
TARGET_LOCATION="London, Remote"
MAX_JOBS_PER_SCAN=25
MATCH_SCORE_THRESHOLD=75

# ── Notification Hub (Optional) ──────────────────────────────
YAHOO_EMAIL=
YAHOO_APP_PASSWORD=

# ── System Settings ──────────────────────────────────────────
HEADLESS_BROWSER=false
TELEMETRY_ENABLED=true
VERSION=25.0.0

# ── Telemetry (Supabase) ─────────────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
